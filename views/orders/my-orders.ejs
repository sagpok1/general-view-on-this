<%- include('../layout/header', { title: 'My Orders', extraCss: ['/css/pages/orders.css', '/css/pages/orders-v2.css', '/css/pages/dashboard.css'] }) %>

<section class="my-orders page-section">

  <!-- ═══ HEADER ═══ -->
  <div class="dash-header">
    <div class="dash-header-content">
      <h1 class="dash-header-title">My orders</h1>
      <p class="dash-header-sub">Track your order history</p>
    </div>
    <div class="ticker-strip">
      <div class="ticker-track">
        <span class="ticker-item"><%= orders.length %> total order<%= orders.length !== 1 ? 's' : '' %></span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Pending &rarr; Accepted &rarr; Ready &rarr; Completed</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Support local</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item"><%= orders.length %> total order<%= orders.length !== 1 ? 's' : '' %></span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Pending &rarr; Accepted &rarr; Ready &rarr; Completed</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Support local</span>
        <span class="ticker-dot"></span>
      </div>
    </div>
  </div>

  <% if (orders.length > 0) { %>
    <div class="o-order-list" data-reveal-stagger="70">
      <% orders.forEach(function(order) {
        var steps = ['pending', 'accepted', 'ready', 'completed'];
        var currentIndex = steps.indexOf(order.status);
        var progress = currentIndex >= 0 ? ((currentIndex) / (steps.length - 1)) * 100 : 0;
      %>
        <div class="o-order pop-reveal o-order-<%= order.status %>">
          <div class="o-order-top">
            <div class="o-order-info">
              <h3 class="o-order-biz"><%= order.business_name %></h3>
              <p class="o-order-items"><%= order.items %></p>
            </div>
            <span class="o-order-badge o-order-badge-<%= order.status %>"><%= order.status %></span>
          </div>

          <div class="o-order-meta">
            <span class="o-order-meta-item">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 7v10M8 11h8" stroke-linecap="round"/></svg>
              <%= order.credits_spent %> credit<%= order.credits_spent === 1 ? '' : 's' %>
            </span>
            <span class="o-order-meta-item">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
              <%= new Date(order.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
            </span>
          </div>

          <% if (order.status !== 'declined') { %>
            <div class="o-order-track" aria-label="Order progress">
              <div class="o-order-track-bar">
                <div class="o-order-track-fill" style="width: <%= progress %>%"></div>
              </div>
              <div class="o-order-track-steps">
                <% steps.forEach(function(step, idx) { %>
                  <span class="o-order-track-step <%= idx <= currentIndex ? 'is-done' : '' %> <%= idx === currentIndex ? 'is-current' : '' %>">
                    <span class="o-order-track-dot"></span>
                    <span class="o-order-track-label"><%= step %></span>
                  </span>
                <% }); %>
              </div>
            </div>
          <% } %>
        </div>
      <% }); %>
    </div>
  <% } else { %>
    <div class="empty-state">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
        <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/>
      </svg>
      <h3>No orders yet</h3>
      <p>You haven't placed any orders. <a href="/orders">Browse businesses</a> to get started.</p>
    </div>
  <% } %>
</section>

<%- include('../layout/footer') %>
