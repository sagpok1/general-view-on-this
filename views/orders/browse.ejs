<%- include('../layout/header', { title: 'Browse Businesses', extraCss: ['/css/pages/orders.css', '/css/pages/dashboard.css'] }) %>

<section class="orders-browse">

  <!-- ═══ ANIMATED GRADIENT HEADER ═══ -->
  <div class="dash-header">
    <div class="dash-header-content">
      <h1 class="dash-header-title">Browse Businesses</h1>
      <p class="dash-header-sub">Discover local shops and services</p>
    </div>
    <div class="ticker-strip">
      <div class="ticker-track">
        <span class="ticker-item"><%= businesses.length %> businesses available</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Support local</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Earn credits through surveys</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Order with credits</span>
        <span class="ticker-dot"></span>
        <!-- Duplicate for seamless loop -->
        <span class="ticker-item"><%= businesses.length %> businesses available</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Support local</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Earn credits through surveys</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Order with credits</span>
        <span class="ticker-dot"></span>
      </div>
    </div>
  </div>

  <form action="/orders" method="GET" class="search-bar">
    <div class="search-bar-inner">
      <div class="search-input-group">
        <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input
          type="text"
          name="q"
          class="form-input search-input"
          placeholder="Search businesses..."
          value="<%= typeof query !== 'undefined' ? query : '' %>"
        >
      </div>

      <div class="search-filter-group">
        <select name="category" class="form-input form-select search-select">
          <option value="" <%= (typeof category === 'undefined' || category === '') ? 'selected' : '' %>>All Categories</option>
          <option value="restaurant" <%= category === 'restaurant' ? 'selected' : '' %>>Restaurant</option>
          <option value="retail" <%= category === 'retail' ? 'selected' : '' %>>Retail</option>
          <option value="service" <%= category === 'service' ? 'selected' : '' %>>Service</option>
          <option value="other" <%= category === 'other' ? 'selected' : '' %>>Other</option>
        </select>
      </div>

      <button type="submit" class="btn btn-primary search-btn">Search</button>
    </div>
  </form>

  <% if (businesses.length > 0) { %>
    <div class="business-grid" data-reveal-stagger="80" data-reveal-max="14">
      <% businesses.forEach(function(biz) { %>
        <div class="business-card pop-reveal anim-glow anim-shine">
          <div class="business-card-header">
            <h2 class="business-card-name"><%= biz.business_name %></h2>
            <span class="badge badge-category badge-<%= biz.category %>"><%= biz.category %></span>
          </div>

          <% if (biz.description) { %>
            <p class="business-card-desc">
              <%= biz.description.length > 120 ? biz.description.substring(0, 120) + '...' : biz.description %>
            </p>
          <% } %>

          <div class="business-card-rating">
            <div class="stars">
              <% var avgRating = biz.avg_rating || 0; %>
              <% for (var i = 1; i <= 5; i++) { %>
                <% if (i <= Math.floor(avgRating)) { %>
                  <svg class="star star-filled" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                <% } else if (i - 0.5 <= avgRating) { %>
                  <svg class="star star-half" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" opacity="0.3"/>
                    <path d="M12 2v15.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                <% } else { %>
                  <svg class="star star-empty" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                <% } %>
              <% } %>
            </div>
            <span class="review-count">(<%= biz.review_count || 0 %> review<%= (biz.review_count || 0) !== 1 ? 's' : '' %>)</span>
          </div>

          <% if (biz.address) { %>
            <div class="business-card-address">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <span><%= biz.address %></span>
            </div>
          <% } %>

          <a href="/orders/create/<%= biz.id %>" class="btn btn-primary btn-block business-card-btn anim-shine">Order Now</a>
        </div>
      <% }); %>
    </div>
  <% } else { %>
    <div class="empty-state">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <h3>No businesses found</h3>
      <p>Try adjusting your search or browse all categories.</p>
    </div>
  <% } %>
</section>

<%- include('../layout/footer', { extraJs: ['/js/search.js'] }) %>
