<%- include('../layout/header', { title: 'Business Dashboard', extraCss: ['/css/pages/dashboard.css', '/css/pages/orders.css'] }) %>

<section class="page-section">

  <!-- ═══ ANIMATED GRADIENT HEADER ═══ -->
  <div class="dash-header">
    <div class="dash-header-content">
      <h1 class="dash-header-title">Business Dashboard</h1>
      <p class="dash-header-sub"><%= business.business_name %></p>
    </div>
    <div class="ticker-strip">
      <div class="ticker-track">
        <span class="ticker-item"><%= stats.pendingCount %> pending order<%= stats.pendingCount !== 1 ? 's' : '' %></span>
        <span class="ticker-dot"></span>
        <span class="ticker-item"><%= stats.totalOrders %> total orders</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Rating: <%= stats.avgRating ? parseFloat(stats.avgRating).toFixed(1) : 'N/A' %></span>
        <span class="ticker-dot"></span>
        <span class="ticker-item"><%= stats.reviewCount %> review<%= stats.reviewCount !== 1 ? 's' : '' %></span>
        <span class="ticker-dot"></span>
        <!-- Duplicate for seamless loop -->
        <span class="ticker-item"><%= stats.pendingCount %> pending order<%= stats.pendingCount !== 1 ? 's' : '' %></span>
        <span class="ticker-dot"></span>
        <span class="ticker-item"><%= stats.totalOrders %> total orders</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Rating: <%= stats.avgRating ? parseFloat(stats.avgRating).toFixed(1) : 'N/A' %></span>
        <span class="ticker-dot"></span>
        <span class="ticker-item"><%= stats.reviewCount %> review<%= stats.reviewCount !== 1 ? 's' : '' %></span>
        <span class="ticker-dot"></span>
      </div>
    </div>
  </div>

  <!-- ═══ STATS CARDS WITH PULSE ANIMATIONS ═══ -->
  <div class="dashboard-stats">
    <div class="stat-card stat-card-orders">
      <div class="stat-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
      </div>
      <div class="stat-value"><%= stats.pendingCount %></div>
      <div class="stat-label">Pending Orders</div>
    </div>

    <div class="stat-card stat-card-surveys">
      <div class="stat-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
          <line x1="8" y1="21" x2="16" y2="21"/>
          <line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
      </div>
      <div class="stat-value"><%= stats.totalOrders %></div>
      <div class="stat-label">Total Orders</div>
    </div>

    <div class="stat-card stat-card-business">
      <div class="stat-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      </div>
      <div class="stat-value">
        <div class="star-display" data-rating="<%= stats.avgRating || 0 %>">
          <% for (var s = 1; s <= 5; s++) { %>
            <span class="star <%= s <= Math.round(stats.avgRating || 0) ? 'star-filled' : 'star-empty' %>">&#9733;</span>
          <% } %>
        </div>
        <span class="stat-rating-number"><%= stats.avgRating ? parseFloat(stats.avgRating).toFixed(1) : 'N/A' %></span>
      </div>
      <div class="stat-label">Average Rating</div>
    </div>

    <div class="stat-card stat-card-orders">
      <div class="stat-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
        </svg>
      </div>
      <div class="stat-value"><%= stats.reviewCount %></div>
      <div class="stat-label">Total Reviews</div>
    </div>
  </div>

  <div class="dashboard-section">
    <div class="section-header">
      <h2 class="section-title">Incoming Orders</h2>
      <a href="/business/orders" class="btn btn-secondary btn-sm">View All Orders</a>
    </div>

    <% if (orders && orders.length > 0) { %>
      <div class="orders-list">
        <% orders.slice(0, 10).forEach(function(order) { %>
          <article class="order-card">
            <div class="order-card-header">
              <span class="order-customer-name"><%= order.customer_name %></span>
              <span class="badge badge-status badge-<%= order.status %>"><%= order.status %></span>
            </div>
            <div class="order-card-body">
              <p class="order-items"><%= order.items_description %></p>
              <div class="order-details">
                <span class="order-credits"><%= order.credits %> Credits</span>
                <time class="order-date"><%= new Date(order.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></time>
              </div>
            </div>
            <div class="order-card-actions">
              <% if (order.status === 'pending') { %>
                <form action="/business/orders/<%= order.id %>" method="POST" class="order-action-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="status" value="accepted">
                  <button type="submit" class="btn btn-primary btn-sm">Accept</button>
                </form>
                <form action="/business/orders/<%= order.id %>" method="POST" class="order-action-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="status" value="declined">
                  <button type="submit" class="btn btn-danger btn-sm">Decline</button>
                </form>
              <% } else if (order.status === 'accepted') { %>
                <form action="/business/orders/<%= order.id %>" method="POST" class="order-action-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="status" value="ready">
                  <button type="submit" class="btn btn-primary btn-sm">Mark Ready</button>
                </form>
              <% } else if (order.status === 'ready') { %>
                <form action="/business/orders/<%= order.id %>" method="POST" class="order-action-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="status" value="completed">
                  <button type="submit" class="btn btn-primary btn-sm">Complete</button>
                </form>
              <% } %>
            </div>
          </article>
        <% }); %>
      </div>
    <% } else { %>
      <div class="empty-state">
        <p class="empty-state-text">No incoming orders yet.</p>
      </div>
    <% } %>
  </div>
</section>

<%- include('../layout/footer') %>
