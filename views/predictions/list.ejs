<%- include('../layout/header', { title: 'Predictions', extraCss: ['/css/pages/predictions.css', '/css/pages/dashboard.css'] }) %>

<section class="page-section">
  <div class="dash-header">
    <div class="dash-header-content">
      <h1 class="dash-header-title">Predictions</h1>
      <p class="dash-header-sub">Forecast outcomes. No money — just community wisdom.</p>
    </div>
    <div class="ticker-strip">
      <div class="ticker-track">
        <span class="ticker-item"><%= stats.totalPredictions %> markets</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item"><%= stats.totalVotes %> predictions cast</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item"><%= stats.uniqueVoters %> forecasters</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">No bets, no stakes</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item"><%= stats.totalPredictions %> markets</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item"><%= stats.totalVotes %> predictions cast</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item"><%= stats.uniqueVoters %> forecasters</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">No bets, no stakes</span>
        <span class="ticker-dot"></span>
      </div>
    </div>
  </div>

  <!-- ═══ STATS STRIP ═══ -->
  <div class="predict-stats-strip" data-reveal>
    <div class="predict-stat">
      <div class="predict-stat-value" data-counter="<%= stats.totalPredictions %>"><%= stats.totalPredictions %></div>
      <div class="predict-stat-label">Open markets</div>
    </div>
    <div class="predict-stat-divider"></div>
    <div class="predict-stat">
      <div class="predict-stat-value" data-counter="<%= stats.totalVotes %>"><%= stats.totalVotes %></div>
      <div class="predict-stat-label">Predictions cast</div>
    </div>
    <div class="predict-stat-divider"></div>
    <div class="predict-stat">
      <div class="predict-stat-value" data-counter="<%= stats.uniqueVoters %>"><%= stats.uniqueVoters %></div>
      <div class="predict-stat-label">Forecasters</div>
    </div>
  </div>

  <div class="predict-toolbar">
    <div class="predict-search-wrap">
      <svg class="predict-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.3-4.3"/>
      </svg>
      <input type="search" id="predictSearch" class="predict-search" placeholder="Search predictions…" aria-label="Search predictions">
    </div>
    <div class="predict-filters" role="tablist" aria-label="Filter by category">
      <button type="button" class="predict-chip is-active" data-cat="all">All</button>
      <% categories.forEach(function(c) { %>
        <button type="button" class="predict-chip" data-cat="<%= c %>" data-cat-color="<%= c %>">
          <span class="predict-chip-dot"></span><%= c.charAt(0).toUpperCase() + c.slice(1) %>
        </button>
      <% }); %>
    </div>
  </div>

  <% if (predictions.length === 0) { %>
    <div class="predict-empty">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 3v18h18"/>
        <path d="M7 16l4-4 4 4 5-5"/>
      </svg>
      <p>No predictions yet. Check back soon.</p>
    </div>
  <% } else { %>
    <div class="predict-grid" id="predictGrid" data-reveal-stagger="70" data-reveal-max="12">
      <% predictions.forEach(function(p) { %>
        <article class="predict-card pop-reveal <%= p.my_option_id ? 'is-voted' : '' %> <%= p.status !== 'open' ? 'is-closed' : '' %>"
                 data-cat="<%= p.category || '' %>"
                 data-search="<%= (p.title + ' ' + (p.description || '')).toLowerCase() %>">
          <span class="predict-card-accent" aria-hidden="true"></span>

          <div class="predict-card-head">
            <span class="badge badge-category predict-cat-badge">
              <span class="predict-cat-dot"></span><%= p.category %>
            </span>
            <% if (p.status === 'open') { %>
              <span class="predict-status predict-status-open">
                <span class="predict-status-pulse"></span>Live
              </span>
            <% } else { %>
              <span class="predict-status predict-status-closed">Closed</span>
            <% } %>
          </div>

          <h3 class="predict-card-title"><%= p.title %></h3>
          <p class="predict-card-desc"><%= p.description %></p>

          <% if (p.total_votes > 0 && p.top_options && p.top_options.length > 0) { %>
            <div class="predict-options-preview">
              <% p.top_options.forEach(function(opt, i) { %>
                <div class="predict-option-row <%= opt.is_mine ? 'is-mine' : '' %> <%= i === 0 ? 'is-lead' : '' %>">
                  <div class="predict-option-row-head">
                    <span class="predict-option-label" title="<%= opt.label %>"><%= opt.label %></span>
                    <span class="predict-option-pct"><%= opt.pct %>%</span>
                  </div>
                  <div class="predict-option-bar">
                    <div class="predict-option-fill" style="width: <%= opt.pct %>%"></div>
                  </div>
                </div>
              <% }); %>
              <% if (p.option_count > 2) { %>
                <div class="predict-options-more">+<%= p.option_count - 2 %> more option<%= p.option_count - 2 === 1 ? '' : 's' %></div>
              <% } %>
            </div>
          <% } else { %>
            <div class="predict-options-preview predict-options-empty">
              <div class="predict-option-bar is-empty"><div class="predict-option-fill" style="width: 0%"></div></div>
              <p class="predict-options-empty-text">Be the first to predict.</p>
            </div>
          <% } %>

          <div class="predict-card-foot">
            <div class="predict-foot-meta">
              <span class="predict-foot-item">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <%= p.total_votes %>
              </span>
              <% if (p.close_date) { %>
                <span class="predict-foot-item">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                  <%= new Date(p.close_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
                </span>
              <% } %>
            </div>
            <a href="/predictions/<%= p.id %>" class="predict-cta">
              <%= p.my_option_id ? 'Results' : 'Predict' %>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      <% }); %>
    </div>
  <% } %>
</section>

<script>
(function() {
  var search = document.getElementById('predictSearch');
  var chips = document.querySelectorAll('.predict-chip');
  var cards = document.querySelectorAll('#predictGrid .predict-card');
  var activeCat = 'all';

  function apply() {
    var q = (search.value || '').trim().toLowerCase();
    cards.forEach(function(card) {
      var catMatch = activeCat === 'all' || card.dataset.cat === activeCat;
      var textMatch = !q || card.dataset.search.indexOf(q) !== -1;
      card.style.display = (catMatch && textMatch) ? '' : 'none';
    });
  }

  chips.forEach(function(c) {
    c.addEventListener('click', function() {
      chips.forEach(function(x) { x.classList.remove('is-active'); });
      c.classList.add('is-active');
      activeCat = c.dataset.cat;
      apply();
    });
  });
  if (search) search.addEventListener('input', apply);

  // Animate the option bars on load
  requestAnimationFrame(function() {
    document.querySelectorAll('.predict-option-fill').forEach(function(el) {
      var w = el.style.width;
      el.style.width = '0%';
      requestAnimationFrame(function() {
        el.style.width = w;
      });
    });
  });
})();
</script>

<%- include('../layout/footer') %>
