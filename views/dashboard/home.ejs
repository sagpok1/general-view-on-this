<%- include('../layout/header', { title: 'Dashboard', extraCss: ['/css/pages/dashboard.css'] }) %>

<section class="dashboard">
  <div class="dashboard-header">
    <h1 class="dashboard-welcome">Welcome back, <%= currentUser.name %></h1>
  </div>

  <div class="dashboard-stats">
    <div class="stat-card stat-card-credits">
      <div class="stat-icon">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
          <circle cx="14" cy="14" r="12" stroke="currentColor" stroke-width="2"/>
          <text x="14" y="18" text-anchor="middle" font-size="14" font-weight="bold" fill="currentColor">C</text>
        </svg>
      </div>
      <div class="stat-value"><%= credits %></div>
      <div class="stat-label">Credit Balance</div>
    </div>

    <div class="stat-card">
      <div class="stat-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 11l3 3L22 4"/>
          <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
        </svg>
      </div>
      <div class="stat-value"><%= surveysCompleted %></div>
      <div class="stat-label">Surveys Completed</div>
    </div>

    <div class="stat-card">
      <div class="stat-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
          <line x1="8" y1="21" x2="16" y2="21"/>
          <line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
      </div>
      <div class="stat-value"><%= recentOrders.length %></div>
      <div class="stat-label">Orders Placed</div>
    </div>

    <% if (typeof businessOrderCount !== 'undefined' && businessOrderCount !== null) { %>
      <div class="stat-card">
        <div class="stat-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
          </svg>
        </div>
        <div class="stat-value"><%= businessOrderCount %></div>
        <div class="stat-label">Incoming Orders</div>
      </div>
    <% } %>
  </div>

  <div class="dashboard-grid">
    <div class="dashboard-col">
      <div class="dashboard-section">
        <h2 class="section-title">Recent Orders</h2>

        <% if (recentOrders.length > 0) { %>
          <div class="order-list">
            <% recentOrders.forEach(function(order) { %>
              <a href="/orders/<%= order.id %>" class="order-card">
                <div class="order-card-header">
                  <span class="order-business-name"><%= order.business_name %></span>
                  <span class="badge badge-<%= order.status %>"><%= order.status %></span>
                </div>
                <div class="order-card-meta">
                  <span class="order-date">
                    <%= new Date(order.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                  </span>
                  <span class="order-credits"><%= order.credits_spent %> credits</span>
                </div>
              </a>
            <% }); %>
          </div>
        <% } else { %>
          <div class="empty-state">
            <p>No orders yet. <a href="/orders">Browse businesses</a> to get started!</p>
          </div>
        <% } %>
      </div>
    </div>

    <div class="dashboard-col">
      <div class="dashboard-section">
        <h2 class="section-title">Quick Actions</h2>

        <div class="quick-actions">
          <a href="/surveys" class="action-card">
            <div class="action-card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10 9 9 9 8 9"/>
              </svg>
            </div>
            <div class="action-card-body">
              <h3>Take a Survey</h3>
              <p><%= surveysAvailable %> survey<%= surveysAvailable !== 1 ? 's' : '' %> available</p>
            </div>
          </a>

          <a href="/orders" class="action-card">
            <div class="action-card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/>
              </svg>
            </div>
            <div class="action-card-body">
              <h3>Browse Businesses</h3>
              <p>Discover local shops and services</p>
            </div>
          </a>

          <% if (typeof businessOrderCount !== 'undefined' && businessOrderCount !== null) { %>
            <a href="/business/orders" class="action-card">
              <div class="action-card-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/>
                  <rect x="8" y="2" width="8" height="4" rx="1" ry="1"/>
                </svg>
              </div>
              <div class="action-card-body">
                <h3>View Incoming Orders</h3>
                <p><%= businessOrderCount %> order<%= businessOrderCount !== 1 ? 's' : '' %> to process</p>
              </div>
            </a>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div class="dashboard-section">
    <h2 class="section-title">Credit History</h2>

    <% if (creditHistory.length > 0) { %>
      <ul class="credit-history-list">
        <% creditHistory.forEach(function(entry) { %>
          <li class="credit-history-item">
            <div class="credit-history-info">
              <span class="credit-history-desc"><%= entry.description %></span>
              <span class="credit-history-date">
                <%= new Date(entry.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
              </span>
            </div>
            <span class="credit-history-amount <%= entry.amount > 0 ? 'credit-positive' : 'credit-negative' %>">
              <%= entry.amount > 0 ? '+' : '' %><%= entry.amount %> credits
            </span>
          </li>
        <% }); %>
      </ul>
    <% } else { %>
      <div class="empty-state">
        <p>No credit transactions yet. Complete surveys to earn credits!</p>
      </div>
    <% } %>
  </div>
</section>

<%- include('../layout/footer') %>
