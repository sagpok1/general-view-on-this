<%- include('../layout/header', { title: 'Dashboard', extraCss: ['/css/pages/dashboard.css'] }) %>

<section class="dashboard">

  <!-- ═══ ANIMATED GRADIENT HEADER ═══ -->
  <div class="dash-header">
    <div class="dash-header-content">
      <h1 class="dash-header-title">Dashboard</h1>
      <p class="dash-header-sub">Your community at a glance</p>
    </div>
    <div class="ticker-strip">
      <div class="ticker-track">
        <span class="ticker-item">Welcome to General View On This</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item"><%= surveysAvailable %> surveys available</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Earn credits by sharing your opinions</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Reviews can never be deleted — radical transparency</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Support local businesses with your credits</span>
        <span class="ticker-dot"></span>
        <!-- Duplicate for seamless loop -->
        <span class="ticker-item">Welcome to General View On This</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item"><%= surveysAvailable %> surveys available</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Earn credits by sharing your opinions</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Reviews can never be deleted — radical transparency</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Support local businesses with your credits</span>
        <span class="ticker-dot"></span>
      </div>
    </div>
  </div>

  <!-- ═══ CLOUD WELCOME BOX ═══ -->
  <div class="cloud-welcome-wrapper" data-reveal>
    <div class="cloud-bump cloud-bump-1"></div>
    <div class="cloud-bump cloud-bump-2"></div>
    <div class="cloud-bump cloud-bump-3"></div>
    <div class="cloud-box">
      <div class="cloud-greeting">
        <span class="cloud-wave">👋</span>
        <div>
          <h2 class="cloud-title">Welcome back, <strong><%= currentUser.name %></strong></h2>
          <p class="cloud-subtitle">You have <strong><%= credits %></strong> credit<%= credits !== 1 ? 's' : '' %> and <strong><%= surveysAvailable %></strong> survey<%= surveysAvailable !== 1 ? 's' : '' %> waiting</p>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ STATS CARDS ═══ -->
  <div class="dashboard-stats" data-reveal-stagger="90">

    <!-- Credit Balance — Coin -->
    <div class="coin-card anim-glow">
      <div class="coin-outer">
        <div class="coin-inner">
          <div class="coin-value" data-counter="<%= credits %>"><%= credits %></div>
          <div class="coin-label">Credits</div>
        </div>
      </div>
    </div>

    <!-- Surveys Completed — Green -->
    <div class="stat-card stat-card-surveys anim-glow">
      <div class="stat-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 11l3 3L22 4"/>
          <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
        </svg>
      </div>
      <div class="stat-value" data-counter="<%= surveysCompleted %>"><%= surveysCompleted %></div>
      <div class="stat-label">Surveys Completed</div>
    </div>

    <!-- Orders Placed — Orange -->
    <div class="stat-card stat-card-orders anim-glow">
      <div class="stat-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
          <line x1="8" y1="21" x2="16" y2="21"/>
          <line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
      </div>
      <div class="stat-value" data-counter="<%= recentOrders.length %>"><%= recentOrders.length %></div>
      <div class="stat-label">Orders Placed</div>
    </div>

    <% if (typeof businessOrderCount !== 'undefined' && businessOrderCount !== null) { %>
      <div class="stat-card stat-card-business anim-glow">
        <div class="stat-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
          </svg>
        </div>
        <div class="stat-value" data-counter="<%= businessOrderCount %>"><%= businessOrderCount %></div>
        <div class="stat-label">Incoming Orders</div>
      </div>
    <% } %>
  </div>

  <!-- ═══ MAIN GRID ═══ -->
  <div class="dashboard-grid">
    <div class="dashboard-col">
      <div class="dashboard-section">
        <h2 class="section-title">Recent Orders</h2>

        <% if (recentOrders.length > 0) { %>
          <div class="order-list" data-reveal-stagger="70">
            <% recentOrders.forEach(function(order) { %>
              <div class="order-card pop-reveal">
                <div class="order-card-header">
                  <span class="order-business-name"><%= order.business_name %></span>
                  <span class="badge badge-<%= order.status %>"><%= order.status %></span>
                </div>
                <div class="order-card-meta">
                  <span class="order-date">
                    <%= new Date(order.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                  </span>
                  <span class="order-credits"><%= order.credits_spent %> credits</span>
                </div>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="empty-state">
            <p>No orders yet. <a href="/orders">Browse businesses</a> to get started!</p>
          </div>
        <% } %>
      </div>
    </div>

    <div class="dashboard-col">
      <div class="dashboard-section">
        <h2 class="section-title">Quick Actions</h2>

        <div class="quick-actions" data-reveal-stagger="80">
          <a href="/surveys" class="action-card anim-glow anim-shine">
            <div class="action-card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10 9 9 9 8 9"/>
              </svg>
            </div>
            <div class="action-card-body">
              <h3>Take a Survey</h3>
              <p><%= surveysAvailable %> survey<%= surveysAvailable !== 1 ? 's' : '' %> available</p>
            </div>
          </a>

          <a href="/orders" class="action-card anim-glow anim-shine">
            <div class="action-card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/>
              </svg>
            </div>
            <div class="action-card-body">
              <h3>Browse Businesses</h3>
              <p>Discover local shops and services</p>
            </div>
          </a>

          <% if (typeof businessOrderCount !== 'undefined' && businessOrderCount !== null) { %>
            <a href="/business/orders" class="action-card anim-glow anim-shine">
              <div class="action-card-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/>
                  <rect x="8" y="2" width="8" height="4" rx="1" ry="1"/>
                </svg>
              </div>
              <div class="action-card-body">
                <h3>View Incoming Orders</h3>
                <p><%= businessOrderCount %> order<%= businessOrderCount !== 1 ? 's' : '' %> to process</p>
              </div>
            </a>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ CREDIT HISTORY ═══ -->
  <div class="dashboard-section">
    <h2 class="section-title">Credit History</h2>

    <% if (creditHistory.length > 0) { %>
      <ul class="credit-history-list">
        <% creditHistory.forEach(function(entry) { %>
          <li class="credit-history-item">
            <div class="credit-history-info">
              <span class="credit-history-desc"><%= entry.reason %></span>
              <span class="credit-history-date">
                <%= new Date(entry.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
              </span>
            </div>
            <span class="credit-history-amount <%= entry.amount > 0 ? 'credit-positive' : 'credit-negative' %>">
              <%= entry.amount > 0 ? '+' : '' %><%= entry.amount %> credits
            </span>
          </li>
        <% }); %>
      </ul>
    <% } else { %>
      <div class="empty-state">
        <p>No credit transactions yet. Complete surveys to earn credits!</p>
      </div>
    <% } %>
  </div>

</section>

<%- include('../layout/footer') %>
