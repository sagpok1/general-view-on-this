<%- include('../layout/header', { title: 'Confessions', extraCss: ['/css/pages/confessions.css'] }) %>

<%
  var EMOJI = { happy:'😊', okay:'😐', sad:'😔', anxious:'😰', frustrated:'😤', numb:'😶', hopeful:'🌱' };
%>

<section class="confess-page" data-page-size="<%= pageSize %>" data-mood="<%= activeMood || '' %>" data-sort="<%= activeSort %>">

  <header class="confess-header">
    <div>
      <h1 class="confess-title">Confessions</h1>
      <p class="confess-sub"><%= totals.total %> shared · <%= totals.hearts %> hearts. Posted under your username.</p>
    </div>
    <a href="/confessions/new" class="confess-new-link">+ Long-form</a>
  </header>

  <!-- ─── Quick composer ─── -->
  <form class="confess-composer" id="confessComposer" method="POST" action="/confessions">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="composer-row">
      <span class="composer-avatar"><%= currentUser.username.slice(0,2).toUpperCase() %></span>
      <textarea name="body" id="composerBody" placeholder="What's on your mind, @<%= currentUser.username %>?" rows="1" minlength="4" maxlength="2000" required></textarea>
    </div>
    <div class="composer-actions" id="composerActions" hidden>
      <select name="mood_tag" id="composerMood">
        <option value="">— mood (optional) —</option>
        <% moods.forEach(function(m){ %>
          <option value="<%= m %>"><%= EMOJI[m] || '·' %> <%= m %></option>
        <% }) %>
      </select>
      <span class="composer-counter" id="composerCounter">0 / 2000</span>
      <button type="submit" class="composer-share">Share</button>
    </div>
  </form>

  <!-- ─── Filters & sort ─── -->
  <div class="confess-toolbar">
    <div class="confess-filters" role="group" aria-label="Filter by mood">
      <a href="/confessions<%= activeSort && activeSort !== 'newest' ? '?sort=' + activeSort : '' %>" class="confess-chip <%= !activeMood ? 'is-active' : '' %>">All</a>
      <% moods.forEach(function(m){ %>
        <a href="/confessions?mood=<%= m %><%= activeSort && activeSort !== 'newest' ? '&sort=' + activeSort : '' %>" class="confess-chip <%= activeMood === m ? 'is-active' : '' %>" data-mood="<%= m %>">
          <span class="chip-emoji" aria-hidden="true"><%= EMOJI[m] || '·' %></span>
          <%= m %>
        </a>
      <% }) %>
    </div>

    <div class="confess-sort" role="group" aria-label="Sort">
      <% var sortLink = function(s) { return '/confessions?sort=' + s + (activeMood ? '&mood=' + activeMood : ''); }; %>
      <a href="<%= sortLink('newest') %>" class="sort-tab <%= activeSort === 'newest' ? 'is-active' : '' %>">Newest</a>
      <a href="<%= sortLink('hearts') %>" class="sort-tab <%= activeSort === 'hearts' ? 'is-active' : '' %>">Most loved</a>
      <a href="<%= sortLink('mine') %>" class="sort-tab <%= activeSort === 'mine' ? 'is-active' : '' %>">Mine</a>
    </div>
  </div>

  <!-- ─── Feed ─── -->
  <div class="confess-feed" id="confessFeed">
    <% if (!confessions.length) { %>
      <div class="confess-empty">
        <p>It's quiet here.</p>
        <p class="confess-empty-sub">
          <% if (activeMood) { %>No one's posted with mood "<%= activeMood %>" yet.<% } else if (activeSort === 'mine') { %>You haven't posted yet.<% } else { %>Be the first to share something.<% } %>
        </p>
      </div>
    <% } %>
    <%- include('_cards', { confessions: confessions, heartedIds: heartedIds, csrfToken: csrfToken, currentUser: currentUser }) %>
  </div>

  <!-- Sentinel for infinite scroll -->
  <div class="confess-sentinel" id="confessSentinel" data-offset="<%= offset + confessions.length %>" data-done="<%= confessions.length < pageSize ? 'true' : 'false' %>">
    <% if (confessions.length >= pageSize) { %>
      <span class="confess-sentinel-spinner" aria-hidden="true"></span>
      <span class="confess-sentinel-text">Loading more…</span>
    <% } else if (confessions.length > 0) { %>
      <span class="confess-sentinel-text">You've reached the end.</span>
    <% } %>
  </div>

</section>

<%- include('../layout/footer', { extraJs: ['/js/confessions.js'] }) %>
