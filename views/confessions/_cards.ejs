<%
  // Reusable card list. Used by full page render and infinite-scroll fragment.
  function truncBody(text, max) {
    if (!text) return '';
    if (text.length <= max) return text;
    return text.slice(0, max).trimEnd() + '…';
  }
  // myReactions: optional Map(confession_id -> reaction_type)
  var myReactions = (typeof reactionsMap !== 'undefined') ? reactionsMap : new Map();
%>
<% confessions.forEach(function(c){ %>
  <% var myReact = myReactions.get(c.id); %>
  <article class="confess-card" data-mood="<%= (c.mood_tag || '').toLowerCase() %>" data-id="<%= c.id %>">
    <% var isLong = (c.body || '').length > 280; %>
    <% if (c.mood_tag || c.user_id === currentUser.id) { %>
      <header class="confess-card-meta">
        <% if (c.mood_tag) { %>
          <span class="confess-mood-pill">feeling <%= c.mood_tag %></span>
        <% } %>
        <% if (c.user_id === currentUser.id) { %>
          <span class="confess-mine-pill">you</span>
        <% } %>
      </header>
    <% } %>

    <% if (isLong) { %>
      <p class="confess-body confess-body-collapsed" data-full="<%= encodeURIComponent(c.body) %>">
        <span class="confess-body-text"><%= truncBody(c.body, 280) %></span>
        <button type="button" class="confess-readmore">Read more</button>
      </p>
    <% } else { %>
      <p class="confess-body"><%= c.body %></p>
    <% } %>

    <footer class="confess-card-foot">
      <span class="confess-author">
        <span class="confess-avatar"><%= c.username.slice(0,2).toUpperCase() %></span>
        <span class="confess-handle">@<%= c.username %></span>
        <span class="confess-time" data-time="<%= new Date(c.created_at).toISOString() %>"><%= new Date(c.created_at).toLocaleString('en-US', { month:'short', day:'numeric' }) %></span>
      </span>

      <div class="confess-actions">
        <form method="POST" action="/confessions/<%= c.id %>/react" class="confess-react-form" data-type="heart">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="type" value="heart">
          <button type="submit" class="confess-react <%= myReact === 'heart' ? 'is-on' : '' %>" aria-label="Heart" title="Heart">
            <span class="confess-react-glyph" aria-hidden="true">♥</span>
            <span class="confess-react-count"><%= c.hearts || 0 %></span>
          </button>
        </form>
        <form method="POST" action="/confessions/<%= c.id %>/react" class="confess-react-form" data-type="support">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="type" value="support">
          <button type="submit" class="confess-react react-support <%= myReact === 'support' ? 'is-on' : '' %>" aria-label="Send support" title="Send support">
            <span class="confess-react-glyph" aria-hidden="true">🫂</span>
            <span class="confess-react-count"><%= c.reactions_support || 0 %></span>
          </button>
        </form>
        <form method="POST" action="/confessions/<%= c.id %>/react" class="confess-react-form" data-type="hopeful">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="type" value="hopeful">
          <button type="submit" class="confess-react react-hopeful <%= myReact === 'hopeful' ? 'is-on' : '' %>" aria-label="Hopeful" title="Hopeful">
            <span class="confess-react-glyph" aria-hidden="true">🌱</span>
            <span class="confess-react-count"><%= c.reactions_hopeful || 0 %></span>
          </button>
        </form>
        <a href="/confessions/<%= c.id %>#comments" class="confess-comments-link" aria-label="Comments">
          <span aria-hidden="true">💬</span>
          <span class="confess-react-count"><%= c.comment_count || 0 %></span>
        </a>
        <% if (c.user_id === currentUser.id || currentUser.is_admin) { %>
          <form method="POST" action="/confessions/<%= c.id %>/delete" class="confess-delete-form" onsubmit="return confirm('Delete this confession? This cannot be undone — comments and reactions go with it.');">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="confess-delete-btn" aria-label="Delete this confession" title="Delete">
              <span aria-hidden="true">🗑</span>
            </button>
          </form>
        <% } %>
      </div>
    </footer>
  </article>
<% }); %>
