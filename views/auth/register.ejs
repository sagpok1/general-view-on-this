<%- include('../layout/header', { title: 'Create account', extraCss: ['/css/pages/auth.css'] }) %>

<section class="auth-container">
  <div class="auth-card">
    <h1 class="auth-title">Create your account</h1>
    <p class="auth-subtitle">No email. No password. Just a username — and a 7-word phrase you'll save to log back in.</p>

    <% if (errors && errors.length) { %>
      <div class="auth-error">
        <ul style="margin:0; padding-left:1.25rem;">
          <% errors.forEach(function(e){ %><li><%= e.msg %></li><% }) %>
        </ul>
      </div>
    <% } %>

    <form action="/auth/register" method="POST" class="auth-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="form-group">
        <label for="username" class="form-label">Pick a username</label>
        <input
          type="text"
          id="username"
          name="username"
          class="form-input"
          placeholder="3–24 chars: letters, numbers, _ or -"
          required
          autocomplete="username"
          pattern="[A-Za-z0-9_-]{3,24}"
          value="<%= (formData && formData.username) || '' %>"
        >
        <small style="color:var(--color-text-secondary, #666); display:block; margin-top:0.4rem;">
          This is what others see when you post. Anonymous confessions stay anonymous regardless.
        </small>
      </div>

      <button type="submit" class="btn btn-primary btn-block">Generate my recovery phrase</button>
    </form>

    <div class="auth-footer">
      <p>Already have an account? <a href="/auth/login">Sign in</a></p>
    </div>
  </div>
</section>

<%- include('../layout/footer') %>
