<%- include('../layout/header', { title: 'Log in', extraCss: ['/css/pages/auth.css'] }) %>

<section class="auth-container">
  <div class="auth-card">
    <h1 class="auth-title">Welcome back</h1>
    <p class="auth-subtitle">Sign in with your username and 7-word recovery phrase.</p>

    <% if (message && message.type === 'error') { %>
      <div class="auth-error"><span><%= message.text %></span></div>
    <% } %>
    <% if (errors && errors.length) { %>
      <div class="auth-error">
        <ul style="margin:0; padding-left:1.25rem;">
          <% errors.forEach(function(e){ %><li><%= e.msg %></li><% }) %>
        </ul>
      </div>
    <% } %>

    <form action="/auth/login" method="POST" class="auth-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="form-group">
        <label for="username" class="form-label">Username</label>
        <input
          type="text"
          id="username"
          name="username"
          class="form-input"
          placeholder="yourname"
          required
          autocomplete="username"
          value="<%= (formData && formData.username) || '' %>"
        >
      </div>

      <div class="form-group">
        <label for="phrase" class="form-label">Recovery phrase (7 words)</label>
        <textarea
          id="phrase"
          name="phrase"
          class="form-input"
          rows="3"
          placeholder="seven words separated by spaces"
          required
          autocomplete="off"
          spellcheck="false"
          autocapitalize="off"
          style="font-family: 'DM Sans', system-ui, sans-serif; resize: vertical;"
        ></textarea>
        <small style="color:var(--color-text-secondary, #666); display:block; margin-top:0.4rem;">
          Spaces or new lines both work. Capitalisation doesn't matter.
        </small>
      </div>

      <button type="submit" class="btn btn-primary btn-block">Sign in</button>
    </form>

    <div class="auth-footer">
      <p>No account yet? <a href="/auth/register">Create one</a> — takes 10 seconds.</p>
    </div>
  </div>
</section>

<%- include('../layout/footer') %>
