<%- include('layout/header', { title: 'Welcome' }) %>

<section style="max-width: 760px; margin: 4rem auto; padding: 0 1.4rem; text-align: center;">
  <h1 style="font-family:'Playfair Display', serif; font-size: clamp(2.4rem, 6vw, 3.6rem); margin: 0 0 1rem; line-height:1.1;">
    A quiet place to share what's on your mind.
  </h1>
  <p style="font-size: 1.15rem; color: #555; line-height: 1.6; margin: 0 auto 1.6rem; max-width: 560px;">
    Confessions, a grounded AI companion, and a daily mood log.
    No email. Just a username and a 7-word phrase you'll save once.
  </p>

  <div style="display:flex; gap:0.7rem; justify-content:center; flex-wrap:wrap; margin-bottom:2.5rem;">
    <a href="/auth/register" class="btn btn-primary" style="font-size:1.05rem; padding:0.8rem 1.6rem;">Create your account</a>
    <a href="/auth/login" style="align-self:center; color:#444; font-weight:600;">I already have one</a>
  </div>

  <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap:1rem; text-align:left;">
    <div style="background:#fff; border:1px solid #ece6dc; border-radius:14px; padding:1.2rem;">
      <div style="font-size:1.6rem;">📝</div>
      <h3 style="margin:0.5rem 0 0.4rem; font-size:1.1rem;">Confessions</h3>
      <p style="margin:0; color:#666; font-size:0.93rem;">Post under your username. Wipe everything in a panic with one password.</p>
    </div>
    <div style="background:#fff; border:1px solid #ece6dc; border-radius:14px; padding:1.2rem;">
      <div style="font-size:1.6rem;">🌿</div>
      <h3 style="margin:0.5rem 0 0.4rem; font-size:1.1rem;">Companion</h3>
      <p style="margin:0; color:#666; font-size:0.93rem;">A warm listener. Risk-aware. Not a therapist.</p>
    </div>
    <div style="background:#fff; border:1px solid #ece6dc; border-radius:14px; padding:1.2rem;">
      <div style="font-size:1.6rem;">🆘</div>
      <h3 style="margin:0.5rem 0 0.4rem; font-size:1.1rem;">Help, always</h3>
      <p style="margin:0; color:#666; font-size:0.93rem;">A crisis button on every page — 988, Samaritans, more.</p>
    </div>
  </div>
</section>

<%- include('layout/footer') %>
