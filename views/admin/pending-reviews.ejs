<%- include('../layout/header', { title: 'Pending Reviews', extraCss: ['/css/pages/reviews.css'] }) %>

<section class="page-section">
  <div class="page-header">
    <h1 class="page-title">Admin: Pending Reviews</h1>
  </div>

  <% if (reviews && reviews.length > 0) { %>
    <div class="reviews-list">
      <% reviews.forEach(function(review) { %>
        <article class="review-card review-card-pending">
          <div class="review-header">
            <div class="review-direction">
              <span class="review-from"><%= review.reviewer_name %></span>
              <span class="review-arrow">&rarr;</span>
              <span class="review-to"><%= review.target_user_name %></span>
            </div>
            <div class="review-meta">
              <div class="star-display" data-rating="<%= review.rating %>">
                <% for (var s = 1; s <= 5; s++) { %>
                  <span class="star <%= s <= review.rating ? 'star-filled' : 'star-empty' %>">&#9733;</span>
                <% } %>
              </div>
              <time class="review-date" datetime="<%= review.created_at %>">
                <%= new Date(review.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
              </time>
            </div>
          </div>
          <div class="review-body">
            <% if (review.title) { %>
              <h4 class="review-title"><%= review.title %></h4>
            <% } %>
            <p class="review-text"><%= review.body %></p>
          </div>
          <div class="review-actions">
            <form action="/admin/reviews/<%= review.id %>/approve" method="POST" class="review-action-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn btn-primary btn-sm">Approve</button>
            </form>
            <form action="/admin/reviews/<%= review.id %>/reject" method="POST" class="review-action-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn btn-danger btn-sm">Reject</button>
            </form>
          </div>
        </article>
      <% }); %>
    </div>
  <% } else { %>
    <div class="empty-state">
      <p class="empty-state-text">No reviews pending verification.</p>
    </div>
  <% } %>
</section>

<%- include('../layout/footer') %>
