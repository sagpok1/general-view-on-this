<%- include('../layout/header', { title: 'Companion' }) %>

<%
  var CATEGORY_LABELS = {
    name: 'Name',
    age: 'Age',
    location: 'Location',
    pet: 'Pet',
    rel: 'Person in your life',
    job: 'Work',
    like: 'You love',
    dislike: 'You don\'t enjoy',
    fear: 'You\'re scared of',
    milestone: 'Recent'
  };
%>

<section class="container" style="max-width: 760px; margin: 2rem auto; padding: 0 1rem;">
  <header style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1rem; gap:1rem; flex-wrap:wrap;">
    <div>
      <h1 style="margin:0; font-family:'Playfair Display', serif; font-size:1.9rem;">Companion</h1>
      <p style="margin:0.2rem 0 0; color:#666; font-size:0.95rem;">A grounded listener. Remembers what you share — see below.</p>
    </div>
    <% if (messages && messages.length) { %>
      <form method="POST" action="/companion/clear" onsubmit="return confirm('Clear this conversation?');">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" style="background:transparent; border:1px solid #d6d6d6; border-radius:999px; padding:0.4rem 0.9rem; color:#666; cursor:pointer; font-size:0.85rem;">Clear chat</button>
      </form>
    <% } %>
  </header>

  <% if (crisisMode) { %>
    <div style="background:#fff8e1; border:2px solid #f5c46a; border-radius:14px; padding:1.2rem; margin-bottom:1rem;">
      <h2 style="margin:0 0 0.5rem; font-size:1.2rem; color:#8a4a00;">Pausing here for a moment.</h2>
      <p style="margin:0 0 0.7rem; color:#5b3a00;">Some of what you wrote sounds heavy. Please reach out:</p>
      <ul style="margin:0 0 0.8rem; padding-left:1.1rem; color:#5b3a00; line-height:1.6;">
        <li><strong>USA</strong> — call or text <a href="tel:988">988</a></li>
        <li><strong>UK</strong> — Samaritans <a href="tel:116123">116 123</a></li>
        <li><strong>Find a line near you</strong> — <a href="https://findahelpline.com" target="_blank" rel="noopener">findahelpline.com</a></li>
      </ul>
      <form method="POST" action="/companion/dismiss-crisis" style="margin:0;">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-primary">I'm safe — return to chat</button>
      </form>
    </div>
  <% } %>

  <div style="background:#fff; border:1px solid #ece6dc; border-radius:14px; padding:1rem; min-height:280px; max-height:60vh; overflow-y:auto; display:flex; flex-direction:column; gap:0.6rem;" id="chatLog">
    <% if (!messages.length) { %>
      <p style="color:#999; text-align:center; margin:auto;">Say what's on your mind. I'm here.</p>
    <% } %>
    <% messages.forEach(function(m){ %>
      <% if (m.role === 'user') { %>
        <div style="align-self:flex-end; background:#3a59c7; color:#fff; border-radius:14px 14px 3px 14px; padding:0.6rem 0.9rem; max-width:80%; line-height:1.45; white-space:pre-wrap;"><%= m.content %></div>
      <% } else { %>
        <div style="align-self:flex-start; background:#f3efe6; color:#222; border-radius:14px 14px 14px 3px; padding:0.6rem 0.9rem; max-width:80%; line-height:1.45; white-space:pre-wrap;"><%= m.content %></div>
      <% } %>
    <% }) %>
  </div>

  <% if (!crisisMode) { %>
    <form method="POST" action="/companion/send" style="display:flex; gap:0.5rem; margin-top:1rem;">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="text" name="message" required maxlength="2000" autocomplete="off" autofocus
        placeholder="Type a message…"
        style="flex:1; padding:0.75rem 1rem; border:1px solid #ddd; border-radius:999px; font-family:inherit; font-size:1rem;">
      <button type="submit" class="btn btn-primary" style="border-radius:999px; padding:0.65rem 1.3rem;">Send</button>
    </form>
  <% } %>

  <!-- ─── What I remember ───────────────────────────────────────── -->
  <section style="margin-top:2rem; background:#faf7f0; border:1px solid #e3d6b8; border-radius:14px; padding:1.2rem 1.3rem;">
    <header style="display:flex; align-items:center; justify-content:space-between; gap:0.6rem; flex-wrap:wrap; margin-bottom:0.7rem;">
      <h2 style="margin:0; font-family:'Playfair Display', serif; font-size:1.2rem;">What I remember about you</h2>
      <% if (facts && facts.length) { %>
        <form method="POST" action="/companion/forget-all" onsubmit="return confirm('Forget everything I have learned about you?');" style="margin:0;">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" style="background:transparent; border:1px solid #b9892a; border-radius:999px; padding:0.3rem 0.8rem; color:#7a5b00; cursor:pointer; font-size:0.82rem; font-weight:600;">Forget everything</button>
        </form>
      <% } %>
    </header>

    <% if (!facts || !facts.length) { %>
      <p style="margin:0; color:#7a5b00; font-size:0.92rem;">
        Nothing yet. As you talk, I'll quietly note things you share — your name, where you live, who matters to you, what you love. You can delete anything below at any time.
      </p>
    <% } else { %>
      <ul style="list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:0.4rem;">
        <% facts.forEach(function(f){ %>
          <li style="display:flex; align-items:center; justify-content:space-between; gap:0.6rem; background:#fff; border:1px solid #ede1bf; border-radius:10px; padding:0.55rem 0.85rem;">
            <div style="display:flex; align-items:baseline; gap:0.6rem; flex-wrap:wrap;">
              <span style="font-size:0.74rem; font-weight:700; color:#7a5b00; text-transform:uppercase; letter-spacing:0.04em;">
                <%= CATEGORY_LABELS[f.category] || f.category %>
              </span>
              <span style="color:#222;"><%= f.value %></span>
            </div>
            <form method="POST" action="/companion/forget/<%= f.id %>" style="margin:0;">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" style="background:transparent; border:none; color:#a32020; cursor:pointer; font-size:0.82rem;" title="Forget this">forget</button>
            </form>
          </li>
        <% }) %>
      </ul>
      <p style="margin:0.7rem 0 0; color:#7a5b00; font-size:0.82rem;">
        I'll mention these back to you when it feels relevant. Anything stored here is local to this app — never sent to a third party.
      </p>
    <% } %>
  </section>
</section>

<script>
  (function() {
    var log = document.getElementById('chatLog');
    if (log) log.scrollTop = log.scrollHeight;
  })();
</script>

<%- include('../layout/footer') %>
