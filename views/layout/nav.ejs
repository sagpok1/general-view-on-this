<aside class="sidebar" id="sidebar" aria-label="Main navigation">
  <a href="/" class="sidebar-brand">
    <span class="sidebar-brand-mark" aria-hidden="true">◐</span>
    <span class="sidebar-brand-text">General View On This</span>
  </a>

  <nav class="sidebar-nav">
    <span class="sidebar-section-label">Daily</span>
    <a href="/dashboard" class="sidebar-link" data-icon="⌂">
      <span class="sidebar-link-icon" aria-hidden="true">⌂</span>
      <span>Dashboard</span>
    </a>
    <a href="/confessions" class="sidebar-link">
      <span class="sidebar-link-icon" aria-hidden="true">✎</span>
      <span>Confessions</span>
    </a>
    <a href="/companion" class="sidebar-link">
      <span class="sidebar-link-icon" aria-hidden="true">✿</span>
      <span>Companion</span>
    </a>
    <a href="/mood" class="sidebar-link">
      <span class="sidebar-link-icon" aria-hidden="true">○</span>
      <span>Mood</span>
    </a>

    <div class="sidebar-divider" role="separator"></div>

    <span class="sidebar-section-label">More</span>
    <a href="/games" class="sidebar-link">
      <span class="sidebar-link-icon" aria-hidden="true">▶</span>
      <span>Arcade</span>
    </a>

    <div class="sidebar-divider" role="separator"></div>

    <a href="/settings" class="sidebar-link">
      <span class="sidebar-link-icon" aria-hidden="true">⚙</span>
      <span>Settings</span>
    </a>
    <% if (currentUser && currentUser.is_admin) { %>
      <a href="/admin/confessions" class="sidebar-link">
        <span class="sidebar-link-icon" aria-hidden="true">⚐</span>
        <span>Admin</span>
      </a>
    <% } %>
  </nav>

  <div class="sidebar-foot">
    <span class="sidebar-user">
      <span class="sidebar-user-avatar" aria-hidden="true"><%= currentUser.username.slice(0,2).toUpperCase() %></span>
      <span class="sidebar-user-name">@<%= currentUser.username %></span>
    </span>
    <a href="/auth/logout" class="sidebar-link sidebar-link-muted">
      <span class="sidebar-link-icon" aria-hidden="true">↪</span>
      <span>Log out</span>
    </a>
  </div>
</aside>
