<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' | General View On This' : 'General View On This' %></title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/animations.css">

  <% if (typeof locals.extraCss !== 'undefined' && Array.isArray(locals.extraCss)) { %>
    <% locals.extraCss.forEach(function(cssPath) { %>
      <link rel="stylesheet" href="<%= cssPath %>">
    <% }); %>
  <% } %>
</head>
<body class="app-body <%= isAuthenticated ? 'is-auth' : 'is-public' %>">

  <% if (isAuthenticated && currentUser) { %>
    <%- include('nav') %>
    <div class="sidebar-backdrop" id="sidebarBackdrop"></div>
  <% } else { %>
    <header class="top-bar">
      <a href="/" class="top-bar-brand">
        <span class="top-bar-brand-full">General View On This</span>
        <span class="top-bar-brand-short">GVOT</span>
      </a>
      <nav class="top-bar-links">
        <a href="/auth/login" class="top-bar-link">Log in</a>
        <a href="/auth/register" class="top-bar-link top-bar-cta">
          <span class="top-bar-cta-full">Create account</span>
          <span class="top-bar-cta-short">Sign up</span>
        </a>
      </nav>
    </header>
  <% } %>

  <div class="app-main <%= isAuthenticated ? 'with-sidebar' : 'no-sidebar' %>">
    <% if (isAuthenticated && currentUser) { %>
      <header class="mobile-bar">
        <button class="mobile-bar-toggle" id="mobileBarToggle" aria-label="Open menu" aria-controls="sidebar" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <a href="/" class="mobile-bar-brand">General View On This</a>
        <span class="mobile-bar-spacer"></span>
      </header>
    <% } %>

    <% if (typeof message !== 'undefined' && message) { %>
      <div class="alert alert-<%= message.type %>" role="alert">
        <span class="alert-text"><%= message.text %></span>
        <button class="alert-close" aria-label="Close alert">&times;</button>
      </div>
    <% } %>

    <main class="main-content">
