<%- include('../layout/header', { title: survey.title, extraCss: ['/css/pages/surveys.css', '/css/pages/dashboard.css'] }) %>

<section class="page-section">

  <!-- ═══ ANIMATED GRADIENT HEADER ═══ -->
  <div class="dash-header">
    <div class="dash-header-content">
      <h1 class="dash-header-title"><%= survey.title %></h1>
      <p class="dash-header-sub"><%= survey.description %></p>
    </div>
    <div class="ticker-strip">
      <div class="ticker-track">
        <span class="ticker-item"><%= questions.length %> question<%= questions.length !== 1 ? 's' : '' %> in this survey</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Earn 1 credit on completion</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Your answers help local businesses</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">All responses are anonymous</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item"><%= questions.length %> question<%= questions.length !== 1 ? 's' : '' %> in this survey</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Earn 1 credit on completion</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Your answers help local businesses</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">All responses are anonymous</span>
        <span class="ticker-dot"></span>
      </div>
    </div>
  </div>

  <!-- ═══ REWARD BANNER ═══ -->
  <div class="take-reward-banner">
    <div class="take-reward-coin">
      <div class="take-coin-outer">
        <div class="take-coin-inner">1</div>
      </div>
    </div>
    <div class="take-reward-text">
      <h3>Complete this survey to earn <strong>1 Credit</strong></h3>
      <p>Credits unlock orders from local businesses. Your voice matters.</p>
    </div>
  </div>

  <!-- ═══ PROGRESS ═══ -->
  <div class="take-progress-wrapper">
    <div class="take-progress-text">
      <span>Question <strong id="currentQuestion">1</strong> of <strong id="totalQuestions"><%= questions.length %></strong></span>
      <span class="take-progress-percent" id="progressPercent"><%= Math.round((1 / questions.length) * 100) %>%</span>
    </div>
    <div class="take-progress-bar">
      <div class="take-progress-fill progress-fill" id="progressFill" style="width: <%= (1 / questions.length) * 100 %>%"></div>
    </div>
  </div>

  <form action="/surveys/<%= survey.id %>/complete" method="POST" class="take-survey-form survey-form" id="surveyForm">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <% questions.forEach(function(question, index) { %>
      <div class="take-question-card question-card survey-question" data-type="<%= question.question_type %>" data-question="<%= index + 1 %>" style="<%= index === 0 ? '' : 'display: none;' %>">
        <div class="take-question-number">Question <%= index + 1 %></div>
        <h3 class="take-question-text"><%= question.question_text %></h3>

        <% if (question.question_type === 'multiple_choice') { %>
          <div class="take-options-grid">
            <% var options = JSON.parse(question.options); %>
            <% options.forEach(function(option, optIndex) { %>
              <label class="take-option">
                <input type="radio" name="question_<%= question.id %>" value="<%= option %>" required>
                <span class="take-option-circle"></span>
                <span class="take-option-label"><%= option %></span>
              </label>
            <% }); %>
          </div>

        <% } else if (question.question_type === 'rating') { %>
          <div class="take-rating-row">
            <% for (var r = 1; r <= 5; r++) { %>
              <label class="take-rating-item">
                <input type="radio" name="question_<%= question.id %>" value="<%= r %>" required>
                <span class="take-rating-coin"><%= r %></span>
              </label>
            <% } %>
          </div>
          <div class="take-rating-labels">
            <span>Poor</span>
            <span>Excellent</span>
          </div>

        <% } else if (question.question_type === 'text') { %>
          <div class="take-textarea-wrap">
            <textarea name="question_<%= question.id %>" rows="4" placeholder="Share your thoughts..." required></textarea>
          </div>
        <% } %>
      </div>
    <% }); %>

    <div class="take-nav">
      <button type="button" class="btn take-btn-prev btn-prev" id="prevBtn" style="display: none;">← Previous</button>
      <div class="take-nav-right">
        <button type="submit" class="btn take-btn-submit-early" id="submitEarlyBtn">
          <span>Submit Now</span>
          <span class="take-btn-coin">+1 ¢</span>
        </button>
        <button type="button" class="btn take-btn-next btn-next" id="nextBtn">Next →</button>
        <button type="submit" class="btn take-btn-submit btn-submit-survey" id="submitBtn" style="display: none;">
          <span>Complete &amp; Earn</span>
          <span class="take-btn-coin">1 ¢</span>
        </button>
      </div>
    </div>

    <p class="take-submit-hint">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
      </svg>
      You can submit early — all questions must be answered first.
    </p>
  </form>

  <!-- Batch Queue Continuation -->
  <div id="batchContinuation" class="batch-continuation" style="display:none;">
    <div class="batch-continuation-inner">
      <span class="batch-dots"></span>
      <span class="batch-text">You have <strong id="batchRemaining">0</strong> more selected surveys in your queue.</span>
      <button type="button" id="clearBatchBtn" class="batch-clear">Clear queue</button>
    </div>
  </div>
</section>

<style>
/* ═══ SURVEY TAKE — ANIMATED THEME ═══ */

@keyframes takeCoinSpin {
  0%, 100% { transform: rotate(0deg); filter: brightness(1); }
  50%      { transform: rotate(5deg); filter: brightness(1.15); }
}

@keyframes takeCoinShine {
  0%   { background-position: 0% 50%; }
  50%  { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

@keyframes takeProgressShimmer {
  0%   { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

@keyframes takeCardSlide {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes takeRatingPulse {
  0%, 100% { transform: scale(1); }
  50%      { transform: scale(1.05); }
}

/* ── REWARD BANNER ── */
.take-reward-banner {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  background: linear-gradient(135deg, #FAC775, #FAEEDA 60%, #FEF3C7);
  border: 1.5px solid #BA7517;
  border-radius: 20px 20px 20px 4px;
  padding: 1.25rem 1.75rem;
  margin-bottom: 2rem;
  box-shadow:
    0 2px 8px rgba(186, 117, 23, 0.15),
    0 8px 24px rgba(250, 199, 117, 0.1);
  position: relative;
  overflow: hidden;
}

.take-reward-banner::before {
  content: '';
  position: absolute;
  top: -30px;
  right: -30px;
  width: 120px;
  height: 120px;
  background: rgba(255, 255, 255, 0.35);
  border-radius: 50%;
}

.take-reward-coin {
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.take-coin-outer {
  width: 70px;
  height: 70px;
  border-radius: 50%;
  padding: 4px;
  background: linear-gradient(135deg, #FAC775, #EF9F27, #BA7517, #EF9F27, #FAC775);
  background-size: 200% 200%;
  animation: takeCoinShine 4s ease-in-out infinite, takeCoinSpin 3s ease-in-out infinite;
  box-shadow: 0 4px 16px rgba(186, 117, 23, 0.35);
  will-change: background-position, transform;
}

.take-coin-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(160deg, #FFF5E0, #FAECC8);
  border: 2px dashed rgba(186, 117, 23, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-size: 1.75rem;
  font-weight: 700;
  color: #7A5A1A;
}

.take-reward-text {
  flex: 1;
  position: relative;
  z-index: 1;
}

.take-reward-text h3 {
  font-family: var(--font-display);
  font-size: 1.1rem;
  font-weight: 400;
  color: #5A3A0A;
  margin-bottom: 2px;
}

.take-reward-text h3 strong {
  font-weight: 700;
}

.take-reward-text p {
  font-size: 0.85rem;
  color: #7A5A1A;
}

/* ── PROGRESS BAR ── */
.take-progress-wrapper {
  margin-bottom: 2rem;
}

.take-progress-text {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
  font-size: 0.9rem;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.take-progress-text strong {
  color: var(--color-accent);
  font-weight: 700;
}

.take-progress-percent {
  font-family: var(--font-display);
  font-size: 1.1rem;
  color: var(--color-accent);
  font-weight: 700;
}

.take-progress-bar {
  height: 14px;
  background: rgba(232, 98, 42, 0.08);
  border-radius: 999px;
  overflow: hidden;
  position: relative;
  border: 1px solid rgba(232, 98, 42, 0.15);
}

.take-progress-fill {
  height: 100%;
  border-radius: 999px;
  background: linear-gradient(90deg, #E8622A 0%, #F59E0B 50%, #E8622A 100%);
  background-size: 200% 100%;
  animation: takeCoinShine 3s ease-in-out infinite;
  transition: width 500ms cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
  box-shadow: 0 0 12px rgba(232, 98, 42, 0.4);
}

.take-progress-fill::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
  animation: takeProgressShimmer 2s ease-in-out infinite;
}

/* ── FORM ── */
.take-survey-form {
  max-width: 720px;
  margin: 0 auto;
}

/* ── QUESTION CARD (Cloud Style) ── */
.take-question-card {
  background: linear-gradient(135deg, #f0f8ff 0%, #e8f4fd 100%);
  border: 1.5px solid rgba(147, 197, 235, 0.4);
  border-radius: 20px 20px 20px 4px;
  padding: 2rem 2.25rem;
  margin-bottom: 1.5rem;
  box-shadow:
    0 2px 8px rgba(147, 197, 235, 0.15),
    0 8px 24px rgba(147, 197, 235, 0.08),
    inset 0 1px 0 rgba(255, 255, 255, 0.8);
  animation: takeCardSlide 0.4s ease both;
}

.take-question-number {
  display: inline-block;
  padding: 4px 12px;
  background: rgba(232, 98, 42, 0.1);
  color: var(--color-accent);
  border-radius: 999px;
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 1rem;
}

.take-question-text {
  font-family: var(--font-display);
  font-size: 1.35rem;
  font-weight: 700;
  color: #1a3a5c;
  line-height: 1.35;
  margin-bottom: 1.5rem;
}

/* ── MULTIPLE CHOICE ── */
.take-options-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 0.75rem;
}

.take-option {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 16px;
  background: rgba(255, 255, 255, 0.85);
  border: 2px solid rgba(147, 197, 235, 0.3);
  border-radius: 12px;
  cursor: pointer;
  transition: all 200ms ease;
  position: relative;
}

.take-option:hover {
  border-color: var(--color-accent);
  background: rgba(255, 255, 255, 1);
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(232, 98, 42, 0.1);
}

.take-option input[type="radio"] {
  position: absolute;
  opacity: 0;
  pointer-events: none;
}

.take-option-circle {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  border: 2px solid var(--color-border);
  background: #fff;
  flex-shrink: 0;
  transition: all 200ms ease;
  position: relative;
}

.take-option input[type="radio"]:checked ~ .take-option-circle {
  border-color: var(--color-accent);
  background: var(--color-accent);
  box-shadow: 0 0 0 4px rgba(232, 98, 42, 0.15);
}

.take-option input[type="radio"]:checked ~ .take-option-circle::after {
  content: '';
  position: absolute;
  inset: 4px;
  background: #fff;
  border-radius: 50%;
}

.take-option:has(input:checked) {
  border-color: var(--color-accent);
  background: linear-gradient(135deg, rgba(253, 240, 235, 1), rgba(255, 255, 255, 1));
  box-shadow: 0 4px 14px rgba(232, 98, 42, 0.15);
}

.take-option-label {
  font-weight: 500;
  color: #1a3a5c;
  font-size: 0.95rem;
}

/* ── RATING COINS ── */
.take-rating-row {
  display: flex;
  justify-content: space-between;
  gap: 0.75rem;
  margin-bottom: 10px;
}

.take-rating-item {
  flex: 1;
  cursor: pointer;
}

.take-rating-item input[type="radio"] {
  position: absolute;
  opacity: 0;
  pointer-events: none;
}

.take-rating-coin {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  aspect-ratio: 1;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.85);
  border: 2.5px solid rgba(147, 197, 235, 0.4);
  font-family: var(--font-display);
  font-size: 1.5rem;
  font-weight: 700;
  color: #4a7a9b;
  transition: all 250ms cubic-bezier(0.4, 0, 0.2, 1);
}

.take-rating-item:hover .take-rating-coin {
  border-color: var(--color-accent);
  color: var(--color-accent);
  transform: scale(1.08);
}

.take-rating-item input[type="radio"]:checked ~ .take-rating-coin {
  background: linear-gradient(135deg, #FAC775, #EF9F27, #BA7517);
  background-size: 200% 200%;
  animation: takeCoinShine 3s ease-in-out infinite, takeRatingPulse 2s ease-in-out infinite;
  border-color: #BA7517;
  color: #fff;
  box-shadow: 0 4px 16px rgba(186, 117, 23, 0.35);
}

.take-rating-labels {
  display: flex;
  justify-content: space-between;
  font-size: 0.75rem;
  color: var(--color-text-muted);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 0 6px;
}

/* ── TEXT AREA ── */
.take-textarea-wrap {
  position: relative;
}

.take-textarea-wrap textarea {
  width: 100%;
  padding: 16px;
  background: rgba(255, 255, 255, 0.85);
  border: 2px solid rgba(147, 197, 235, 0.4);
  border-radius: 14px;
  font-family: var(--font-body);
  font-size: 1rem;
  color: #1a3a5c;
  line-height: 1.6;
  resize: vertical;
  transition: all 200ms ease;
  min-height: 120px;
}

.take-textarea-wrap textarea:focus {
  outline: none;
  border-color: var(--color-accent);
  background: #fff;
  box-shadow: 0 0 0 4px rgba(232, 98, 42, 0.1);
}

/* ── NAVIGATION ── */
.take-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  margin-top: 2rem;
  padding: 1.5rem;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 16px;
  box-shadow: var(--shadow-sm);
}

.take-btn-prev {
  background: var(--color-surface-2);
  color: var(--color-text-secondary);
  border: 1px solid var(--color-border);
  padding: 12px 22px;
  border-radius: 10px;
  font-weight: 600;
  cursor: pointer;
  transition: all 200ms ease;
}

.take-btn-prev:hover {
  background: var(--color-border);
  color: var(--color-text-primary);
}

.take-btn-next {
  background: linear-gradient(135deg, #E8622A 0%, #F59E0B 100%);
  background-size: 200% 200%;
  animation: takeCoinShine 4s ease-in-out infinite;
  color: #fff;
  border: none;
  padding: 14px 32px;
  border-radius: 10px;
  font-weight: 700;
  font-size: 1rem;
  cursor: pointer;
  transition: all 200ms ease;
  box-shadow: 0 4px 14px rgba(232, 98, 42, 0.25);
  margin-left: auto;
}

.take-btn-next:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(232, 98, 42, 0.35);
}

.take-btn-submit {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: linear-gradient(135deg, #FAC775, #EF9F27, #BA7517);
  background-size: 200% 200%;
  animation: takeCoinShine 3s ease-in-out infinite;
  color: #fff;
  border: none;
  padding: 14px 24px 14px 28px;
  border-radius: 10px;
  font-weight: 700;
  font-size: 1rem;
  cursor: pointer;
  transition: all 200ms ease;
  box-shadow: 0 4px 16px rgba(186, 117, 23, 0.35);
  margin-left: auto;
}

.take-btn-submit:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 22px rgba(186, 117, 23, 0.5);
}

.take-btn-coin {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 38px;
  height: 28px;
  padding: 0 10px;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(4px);
  border-radius: 999px;
  font-size: 0.85rem;
  font-weight: 800;
}

.take-nav-right {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-left: auto;
}

/* ── Submit Early Button ── */
.take-btn-submit-early {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: #fff;
  color: var(--color-accent);
  border: 2px solid var(--color-accent);
  padding: 11px 20px;
  border-radius: 10px;
  font-weight: 700;
  font-size: 0.9rem;
  cursor: pointer;
  transition: all 200ms ease;
}

.take-btn-submit-early:hover {
  background: var(--color-accent);
  color: #fff;
  transform: translateY(-2px);
  box-shadow: 0 4px 14px rgba(232, 98, 42, 0.25);
}

.take-btn-submit-early .take-btn-coin {
  background: rgba(232, 98, 42, 0.1);
  color: var(--color-accent);
}

.take-btn-submit-early:hover .take-btn-coin {
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
}

/* Hide early submit once user is on last question (the Complete button takes over) */
.take-btn-submit-early.is-hidden {
  display: none;
}

/* ── Submit Hint ── */
.take-submit-hint {
  display: flex;
  align-items: center;
  gap: 6px;
  justify-content: center;
  margin-top: 12px;
  font-size: 0.8rem;
  color: var(--color-text-muted);
  font-style: italic;
}

.take-submit-hint svg {
  flex-shrink: 0;
  opacity: 0.6;
}

/* ── Batch Continuation Banner ── */
.batch-continuation {
  margin-top: 1.5rem;
  padding: 14px 18px;
  background: linear-gradient(135deg, #EAF3DE, #DCEBC3);
  border: 1.5px solid #639922;
  border-radius: 14px;
  animation: takeCardSlide 0.4s ease both;
}

.batch-continuation-inner {
  display: flex;
  align-items: center;
  gap: 12px;
  color: #2D5A0A;
  font-size: 0.9rem;
}

.batch-continuation-inner strong {
  font-weight: 700;
  color: #1A4A00;
}

.batch-dots {
  display: inline-flex;
  gap: 4px;
  flex-shrink: 0;
}

.batch-dots::before,
.batch-dots::after {
  content: '';
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #639922;
  animation: takeRatingPulse 1.5s ease-in-out infinite;
}

.batch-dots::after {
  animation-delay: 0.3s;
}

.batch-text {
  flex: 1;
}

.batch-clear {
  background: transparent;
  border: 1px solid #639922;
  color: #2D5A0A;
  font-size: 0.8rem;
  padding: 5px 12px;
  border-radius: 8px;
  cursor: pointer;
  font-weight: 600;
  transition: all 150ms ease;
}

.batch-clear:hover {
  background: #639922;
  color: #fff;
}

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  .take-reward-banner {
    flex-direction: column;
    text-align: center;
    padding: 1.25rem;
  }

  .take-coin-outer {
    width: 60px;
    height: 60px;
  }

  .take-coin-inner {
    font-size: 1.5rem;
  }

  .take-question-card {
    padding: 1.5rem 1.25rem;
  }

  .take-question-text {
    font-size: 1.15rem;
  }

  .take-options-grid {
    grid-template-columns: 1fr;
  }

  .take-rating-coin {
    font-size: 1.25rem;
  }

  .take-nav {
    padding: 1rem;
  }

  .take-btn-next,
  .take-btn-submit {
    padding: 12px 22px;
    font-size: 0.9rem;
  }
}
</style>

<script>
// Update question counter + percent when progress bar width changes
(function() {
  var fill = document.getElementById('progressFill');
  var currentEl = document.getElementById('currentQuestion');
  var percentEl = document.getElementById('progressPercent');
  var totalEl = document.getElementById('totalQuestions');
  if (!fill || !currentEl || !percentEl || !totalEl) return;

  var total = parseInt(totalEl.textContent, 10);
  var observer = new MutationObserver(function() {
    var width = parseFloat(fill.style.width);
    if (!isNaN(width)) {
      var currentQ = Math.round((width / 100) * total);
      if (currentQ < 1) currentQ = 1;
      currentEl.textContent = currentQ;
      percentEl.textContent = Math.round(width) + '%';
    }
  });
  observer.observe(fill, { attributes: true, attributeFilter: ['style'] });
})();

// Early Submit — validates all questions are answered before submitting
(function() {
  var form = document.getElementById('surveyForm');
  var earlyBtn = document.getElementById('submitEarlyBtn');
  var submitBtn = document.getElementById('submitBtn');
  var nextBtn = document.getElementById('nextBtn');
  if (!form || !earlyBtn) return;

  // Hide early submit when on last question (the big Complete button is active there)
  function updateEarlyVisibility() {
    if (submitBtn && submitBtn.style.display !== 'none') {
      earlyBtn.classList.add('is-hidden');
    } else {
      earlyBtn.classList.remove('is-hidden');
    }
  }

  // Observe submitBtn visibility changes (set by survey.js)
  if (submitBtn) {
    var submitObserver = new MutationObserver(updateEarlyVisibility);
    submitObserver.observe(submitBtn, { attributes: true, attributeFilter: ['style'] });
    updateEarlyVisibility();
  }

  earlyBtn.addEventListener('click', function(e) {
    e.preventDefault();

    // Validate: every question must have an answer
    var cards = form.querySelectorAll('.question-card');
    var missing = null;

    for (var i = 0; i < cards.length; i++) {
      var card = cards[i];
      var type = card.dataset.type;
      var answered = false;

      if (type === 'multiple_choice' || type === 'rating') {
        answered = !!card.querySelector('input[type="radio"]:checked');
      } else if (type === 'text') {
        var ta = card.querySelector('textarea');
        answered = ta && ta.value.trim().length > 0;
      }

      if (!answered) {
        missing = i;
        break;
      }
    }

    if (missing !== null) {
      // Jump to the first unanswered question
      cards.forEach(function(c, i) {
        c.style.display = i === missing ? 'block' : 'none';
        c.classList.toggle('active', i === missing);
      });

      // Update progress bar to reflect new position
      var total = cards.length;
      var fill = document.getElementById('progressFill');
      if (fill) fill.style.width = (((missing + 1) / total) * 100) + '%';

      // Update prev/next buttons
      var prevBtn = document.getElementById('prevBtn');
      if (prevBtn) prevBtn.style.display = missing === 0 ? 'none' : 'inline-flex';
      if (nextBtn) nextBtn.style.display = missing === total - 1 ? 'none' : 'inline-flex';
      if (submitBtn) submitBtn.style.display = missing === total - 1 ? 'inline-flex' : 'none';

      // Shake + toast
      cards[missing].style.animation = 'shake 0.4s ease';
      setTimeout(function() { cards[missing].style.animation = ''; }, 450);

      if (typeof window.showToast === 'function') {
        window.showToast('Please answer this question before submitting.', 'error');
      } else {
        alert('Please answer all questions before submitting.');
      }
      return;
    }

    // All answered — confirm and submit
    if (confirm('Submit your responses and earn 1 credit?')) {
      form.submit();
    }
  });
})();

// Session counter — tracks every survey completed during this browser session
// and shows cumulative credits on the Submit button
(function() {
  var QUEUE_KEY = 'gvot_survey_queue';
  var COMPLETED_KEY = 'gvot_survey_session_completed';
  var ACTIVE_KEY = 'gvot_survey_queue_active';
  var banner = document.getElementById('batchContinuation');
  var remainingEl = document.getElementById('batchRemaining');
  var clearBtn = document.getElementById('clearBatchBtn');

  var queue = [];
  try { queue = JSON.parse(sessionStorage.getItem(QUEUE_KEY) || '[]'); } catch (e) { queue = []; }

  // Completed count for THIS session (increments on every survey submission)
  var completed = parseInt(sessionStorage.getItem(COMPLETED_KEY) || '0', 10);
  if (isNaN(completed)) completed = 0;

  // Current survey ID from URL
  var match = window.location.pathname.match(/\/surveys\/(\d+)/);
  var currentId = match ? parseInt(match[1], 10) : null;

  // Remove current ID from queue (if it's there) so it doesn't retrigger
  if (currentId !== null && queue.length > 0) {
    queue = queue.filter(function(id) { return id !== currentId; });
    sessionStorage.setItem(QUEUE_KEY, JSON.stringify(queue));
  }

  // Submit button will earn 1 credit for THIS survey +
  // cumulative credits already earned in session
  var creditsAfterThis = completed + 1;
  var coinLabels = document.querySelectorAll('.take-btn-coin');
  var earlyBtn = document.getElementById('submitEarlyBtn');
  var submitBtn = document.getElementById('submitBtn');

  coinLabels.forEach(function(el) {
    el.textContent = '+' + creditsAfterThis + ' ¢';
  });

  // Update full text on main submit button too
  if (submitBtn) {
    var submitText = submitBtn.querySelector('span:first-child');
    if (submitText) {
      if (creditsAfterThis > 1) {
        submitText.textContent = 'Complete & Earn (' + creditsAfterThis + ' total)';
      } else {
        submitText.textContent = 'Complete & Earn';
      }
    }
  }

  // Batch queue banner
  if (banner && queue.length > 0) {
    banner.style.display = 'block';
    if (remainingEl) remainingEl.textContent = queue.length;
  }

  if (clearBtn) {
    clearBtn.addEventListener('click', function() {
      sessionStorage.removeItem(QUEUE_KEY);
      if (banner) banner.style.display = 'none';
    });
  }

  // Increment completed counter on EVERY survey submission (batch or individual)
  var form = document.getElementById('surveyForm');
  if (form) {
    form.addEventListener('submit', function() {
      sessionStorage.setItem(COMPLETED_KEY, String(completed + 1));
      if (queue.length > 0) {
        sessionStorage.setItem(ACTIVE_KEY, '1');
      }
    });
  }
})();
</script>

