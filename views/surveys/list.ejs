<%- include('../layout/header', { title: 'Surveys', extraCss: ['/css/pages/surveys.css', '/css/pages/surveys-v2.css', '/css/pages/dashboard.css'] }) %>

<section class="page-section">

  <!-- ═══ HEADER ═══ -->
  <div class="dash-header">
    <div class="dash-header-content">
      <h1 class="dash-header-title">Surveys</h1>
      <p class="dash-header-sub">One credit per survey · Share your view</p>
    </div>
    <div class="ticker-strip">
      <div class="ticker-track">
        <span class="ticker-item"><%= availableSurveys ? availableSurveys.length : 0 %> surveys available</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Each survey = 1 credit</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Spend credits at local businesses</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item"><%= availableSurveys ? availableSurveys.length : 0 %> surveys available</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Each survey = 1 credit</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Spend credits at local businesses</span>
        <span class="ticker-dot"></span>
      </div>
    </div>
  </div>

  <!-- ═══ AVAILABLE ═══ -->
  <div class="s-section">
    <div class="s-section-head">
      <div>
        <h2 class="s-section-title">Available</h2>
        <p class="s-section-sub"><%= availableSurveys ? availableSurveys.length : 0 %> waiting for you</p>
      </div>
      <div class="s-balance-chip" title="Your credit balance">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 7v10M8 11h8" stroke-linecap="round"/></svg>
        <strong><%= currentUser.credits %></strong>
        <span>credit<%= currentUser.credits === 1 ? '' : 's' %></span>
      </div>
    </div>

    <% if (availableSurveys && availableSurveys.length > 0) { %>
      <div class="s-toolbar">
        <div class="s-search-wrap">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="search" id="surveySearch" class="s-search" placeholder="Search…" aria-label="Search surveys">
        </div>
        <div class="s-chips" id="surveyFilterChips">
          <button type="button" class="s-chip is-active" data-cat="all">All</button>
          <%
            var cats = [];
            availableSurveys.forEach(function(s) { if (s.category && cats.indexOf(s.category) === -1) cats.push(s.category); });
            cats.forEach(function(c) {
          %>
            <button type="button" class="s-chip" data-cat="<%= c %>"><%= c.charAt(0).toUpperCase() + c.slice(1) %></button>
          <% }); %>
        </div>
        <button type="button" class="s-batch-toggle" id="batchToggle" aria-pressed="false" title="Select multiple">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
          <span>Multi-select</span>
        </button>
      </div>
      <p class="s-empty-filter" id="surveyEmptyFilter" hidden>No surveys match that filter.</p>

      <div class="s-grid" id="surveyGrid" data-reveal-stagger="50" data-reveal-max="16">
        <% availableSurveys.forEach(function(survey) { %>
          <article class="s-card pop-reveal" data-survey-id="<%= survey.id %>"
                   data-cat="<%= survey.category || '' %>"
                   data-search="<%= (survey.title + ' ' + (survey.description || '')).toLowerCase() %>">
            <label class="s-card-check">
              <input type="checkbox" class="survey-check" value="<%= survey.id %>">
              <span class="s-card-check-mark" aria-hidden="true"></span>
            </label>

            <a href="/surveys/<%= survey.id %>" class="s-card-link">
              <div class="s-card-head">
                <span class="s-card-cat">
                  <span class="s-card-cat-dot"></span><%= survey.category %>
                </span>
                <span class="s-card-reward">+1</span>
              </div>
              <h3 class="s-card-title"><%= survey.title %></h3>
              <span class="s-card-cta">
                Take survey
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          </article>
        <% }); %>
      </div>

      <!-- Floating batch action bar (visible when cards selected) -->
      <div class="s-batch-bar" id="batchBar" hidden>
        <button type="button" class="s-batch-link" id="selectAllLink">Select all visible</button>
        <span class="s-batch-count"><span id="batchCount">0</span> selected</span>
        <button type="button" class="btn btn-primary s-batch-go" id="takeBatchBtn" disabled>
          Take selected
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
      </div>

    <% } else { %>
      <div class="empty-state">
        <p class="empty-state-text">You've completed all available surveys.</p>
      </div>
    <% } %>
  </div>

  <!-- ═══ COMPLETED (collapsible) ═══ -->
  <div class="s-section s-section-completed">
    <button type="button" class="s-collapse-head" id="completedToggle" aria-expanded="false">
      <div>
        <h2 class="s-section-title">Completed</h2>
        <p class="s-section-sub"><%= completedSurveys ? completedSurveys.length : 0 %> finished</p>
      </div>
      <svg class="s-collapse-chev" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
    </button>

    <div class="s-collapse-body" id="completedBody" hidden>
      <% if (completedSurveys && completedSurveys.length > 0) { %>
        <ul class="s-completed-list">
          <% completedSurveys.forEach(function(survey) { %>
            <li class="s-completed-row">
              <span class="s-completed-check" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span class="s-completed-cat"><%= survey.category %></span>
              <span class="s-completed-title"><%= survey.title %></span>
              <span class="s-completed-date"><%= new Date(survey.completed_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></span>
            </li>
          <% }); %>
        </ul>
      <% } else { %>
        <div class="empty-state">
          <p class="empty-state-text">You haven't completed any surveys yet.</p>
        </div>
      <% } %>
    </div>
  </div>
</section>

<script>
// ─── Filter + search ─────────────────────────────────────────────
(function() {
  var search = document.getElementById('surveySearch');
  var chipWrap = document.getElementById('surveyFilterChips');
  var grid = document.getElementById('surveyGrid');
  var emptyFilter = document.getElementById('surveyEmptyFilter');
  if (!search || !chipWrap || !grid) return;

  var chips = chipWrap.querySelectorAll('.s-chip');
  var cards = grid.querySelectorAll('.s-card');
  var activeCat = 'all';

  function apply() {
    var q = (search.value || '').trim().toLowerCase();
    var visible = 0;
    cards.forEach(function(card) {
      var catMatch = activeCat === 'all' || card.dataset.cat === activeCat;
      var textMatch = !q || (card.dataset.search || '').indexOf(q) !== -1;
      var show = catMatch && textMatch;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (emptyFilter) emptyFilter.hidden = visible > 0;
  }

  chips.forEach(function(c) {
    c.addEventListener('click', function() {
      chips.forEach(function(x) { x.classList.remove('is-active'); });
      c.classList.add('is-active');
      activeCat = c.dataset.cat;
      apply();
    });
  });
  search.addEventListener('input', apply);
})();

// ─── Multi-select mode + batch take ──────────────────────────────
(function() {
  var KEY = 'gvot_survey_queue';
  var ACTIVE_KEY = 'gvot_survey_queue_active';
  var toggle = document.getElementById('batchToggle');
  var bar = document.getElementById('batchBar');
  var goBtn = document.getElementById('takeBatchBtn');
  var countEl = document.getElementById('batchCount');
  var selectAllLink = document.getElementById('selectAllLink');
  var grid = document.getElementById('surveyGrid');
  if (!toggle || !bar || !goBtn || !grid) return;

  var cards = grid.querySelectorAll('.s-card');
  var checks = grid.querySelectorAll('.survey-check');
  var enabled = false;

  function setEnabled(v) {
    enabled = v;
    toggle.classList.toggle('is-on', v);
    toggle.setAttribute('aria-pressed', v ? 'true' : 'false');
    grid.classList.toggle('s-grid-selectmode', v);
    bar.hidden = !v;
    if (!v) {
      checks.forEach(function(c) { c.checked = false; });
      cards.forEach(function(card) { card.classList.remove('is-selected'); });
      updateCount();
    }
  }

  function updateCount() {
    var selected = Array.from(checks).filter(function(c) { return c.checked; });
    countEl.textContent = selected.length;
    goBtn.disabled = selected.length === 0;
    checks.forEach(function(c) {
      var card = c.closest('.s-card');
      if (card) card.classList.toggle('is-selected', c.checked);
    });
  }

  toggle.addEventListener('click', function() { setEnabled(!enabled); });

  // Clicking the card link while in select-mode toggles the checkbox
  cards.forEach(function(card) {
    var link = card.querySelector('.s-card-link');
    var check = card.querySelector('.survey-check');
    if (!link || !check) return;
    link.addEventListener('click', function(e) {
      if (!enabled) return;
      e.preventDefault();
      check.checked = !check.checked;
      updateCount();
    });
  });

  checks.forEach(function(c) { c.addEventListener('change', updateCount); });

  selectAllLink.addEventListener('click', function() {
    var visibleChecks = Array.from(checks).filter(function(c) {
      var card = c.closest('.s-card');
      return card && card.style.display !== 'none';
    });
    var allOn = visibleChecks.every(function(c) { return c.checked; });
    visibleChecks.forEach(function(c) { c.checked = !allOn; });
    updateCount();
  });

  goBtn.addEventListener('click', function() {
    var selected = Array.from(checks)
      .filter(function(c) { return c.checked; })
      .map(function(c) { return parseInt(c.value, 10); });
    if (selected.length === 0) return;
    var first = selected[0];
    var rest = selected.slice(1);
    sessionStorage.setItem(KEY, JSON.stringify(rest));
    sessionStorage.setItem('gvot_survey_session_completed', '0');
    window.location.href = '/surveys/' + first;
  });

  // Handle batch progress (carry over from previous page)
  var queue = [];
  try { queue = JSON.parse(sessionStorage.getItem(KEY) || '[]'); } catch (e) { queue = []; }
  var completed = parseInt(sessionStorage.getItem('gvot_survey_session_completed') || '0', 10);
  if (queue.length > 0 && sessionStorage.getItem(ACTIVE_KEY)) {
    sessionStorage.removeItem(ACTIVE_KEY);
    var nextId = queue[0];
    if (typeof window.showToast === 'function') {
      window.showToast('Earned ' + completed + ' credit' + (completed !== 1 ? 's' : '') + ' — next survey…', 'success');
    }
    setTimeout(function() { window.location.href = '/surveys/' + nextId; }, 1000);
  } else if (completed > 0 && queue.length === 0) {
    sessionStorage.removeItem(ACTIVE_KEY);
    if (typeof window.showToast === 'function') {
      window.showToast('Earned ' + completed + ' credit' + (completed !== 1 ? 's' : '') + ' this session', 'success');
    }
  }
})();

// ─── Completed section collapse ──────────────────────────────────
(function() {
  var btn = document.getElementById('completedToggle');
  var body = document.getElementById('completedBody');
  if (!btn || !body) return;
  btn.addEventListener('click', function() {
    var open = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', open ? 'false' : 'true');
    btn.classList.toggle('is-open', !open);
    body.hidden = open;
  });
})();
</script>

<%- include('../layout/footer', { extraJs: ['/js/survey.js'] }) %>
