<%- include('../layout/header', { title: 'Surveys', extraCss: ['/css/pages/surveys.css', '/css/pages/dashboard.css'] }) %>

<section class="page-section">

  <!-- ═══ ANIMATED GRADIENT HEADER ═══ -->
  <div class="dash-header">
    <div class="dash-header-content">
      <h1 class="dash-header-title">Surveys</h1>
      <p class="dash-header-sub">Complete surveys to earn credits</p>
    </div>
    <div class="ticker-strip">
      <div class="ticker-track">
        <span class="ticker-item">Each survey = 1 credit</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item"><%= availableSurveys ? availableSurveys.length : 0 %> surveys available</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Share your opinions</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Credits can be used to order from local businesses</span>
        <span class="ticker-dot"></span>
        <!-- Duplicate for seamless loop -->
        <span class="ticker-item">Each survey = 1 credit</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item"><%= availableSurveys ? availableSurveys.length : 0 %> surveys available</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Share your opinions</span>
        <span class="ticker-dot"></span>
        <span class="ticker-item">Credits can be used to order from local businesses</span>
        <span class="ticker-dot"></span>
      </div>
    </div>
  </div>

  <!-- ═══ CREDIT BALANCE COIN CARD ═══ -->
  <div class="dashboard-stats" style="justify-content: center; margin-bottom: 1.5rem;">
    <div class="coin-card">
      <div class="coin-outer">
        <div class="coin-inner">
          <div class="coin-value"><%= currentUser.credits %></div>
          <div class="coin-label">Credits</div>
        </div>
      </div>
    </div>
  </div>

  <div class="survey-section">
    <h2 class="section-title">Available Surveys</h2>

    <% if (availableSurveys && availableSurveys.length > 0) { %>
      <div class="survey-grid">
        <% availableSurveys.forEach(function(survey) { %>
          <article class="survey-card">
            <div class="survey-card-body">
              <span class="badge badge-category"><%= survey.category %></span>
              <h3 class="survey-card-title"><%= survey.title %></h3>
              <p class="survey-card-description"><%= survey.description %></p>
            </div>
            <div class="survey-card-footer">
              <a href="/surveys/<%= survey.id %>" class="btn btn-primary">Take Survey</a>
            </div>
          </article>
        <% }); %>
      </div>
    <% } else { %>
      <div class="empty-state">
        <p class="empty-state-text">You've completed all available surveys!</p>
      </div>
    <% } %>
  </div>

  <div class="survey-section">
    <h2 class="section-title">Completed Surveys</h2>

    <% if (completedSurveys && completedSurveys.length > 0) { %>
      <div class="survey-grid">
        <% completedSurveys.forEach(function(survey) { %>
          <article class="survey-card survey-card-completed">
            <div class="survey-completed-overlay">
              <span class="badge badge-completed">Completed</span>
            </div>
            <div class="survey-card-body">
              <span class="badge badge-category"><%= survey.category %></span>
              <h3 class="survey-card-title"><%= survey.title %></h3>
              <p class="survey-card-description"><%= survey.description %></p>
            </div>
            <div class="survey-card-footer">
              <span class="survey-completed-date">Completed on <%= new Date(survey.completed_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></span>
            </div>
          </article>
        <% }); %>
      </div>
    <% } else { %>
      <div class="empty-state">
        <p class="empty-state-text">You haven't completed any surveys yet.</p>
      </div>
    <% } %>
  </div>
</section>

<%- include('../layout/footer', { extraJs: ['/js/survey.js'] }) %>
